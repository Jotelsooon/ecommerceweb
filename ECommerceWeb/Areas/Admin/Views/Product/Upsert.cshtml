@model ECommerceWeb.Models.Product
@{
    ViewData["Title"] = Model.Id == 0 ? "Nuevo producto" : "Editar producto";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-4">@ViewData["Title"]</h2>
        <form method="post" enctype="multipart/form-data">
            <input asp-for="Id" hidden />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nombre</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label">Precio</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Categoría</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                        class="form-select">
                    <option value="">-- Seleccioná una categoría --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Imagen</label>
                <input type="file" name="file" class="form-control" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.ImageUrl"
                             style="width:120px;height:120px;object-fit:cover;border-radius:8px;" />
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-dark">Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>