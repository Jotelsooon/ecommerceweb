@model ECommerceWeb.Models.Category
@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-4 mx-auto" style="max-width: 600px;">
        <div class="card-body p-4 p-md-5">
            <h3 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-pen-to-square me-2"></i>Editar Categoría</h3>
            
            <form method="post">
                <input asp-for="Id" hidden />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold text-muted">Nombre</label>
                    <input asp-for="Name" class="form-control rounded-3 bg-light border-0 py-2" />
                    <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="DisplayOrder" class="form-label fw-semibold text-muted">Orden de Visualización</label>
                    <input asp-for="DisplayOrder" class="form-control rounded-3 bg-light border-0 py-2" />
                    <span asp-validation-for="DisplayOrder" class="text-danger small mt-1"></span>
                </div>
                
                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">Actualizar</button>
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 text-muted fw-semibold border">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}