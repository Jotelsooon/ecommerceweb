<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Repuestos La Central</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800;900&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light sticky-top bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="central-logo-container" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <span class="central-logo-icon">
                        <i class="fa-solid fa-flag-checkered"></i>
                    </span>
                    <span class="central-logo-text">
                        <span class="central-logo-top">REPUESTOS</span>
                        <span class="central-logo-bottom">LA CENTRAL</span>
                    </span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link px-3 fw-semibold" asp-area="Customer" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 fw-semibold" href="#">Catálogo Digital</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 fw-semibold" href="#">Sucursales</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-3 fw-semibold" role="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-wrench"></i> Admin
                                </a>
                                <ul class="dropdown-menu border-0 shadow-sm">
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Category" asp-action="Index">Categorías de Repuestos</a></li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Product" asp-action="Index">Inventario</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item me-2">
                            <a class="nav-link" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping fs-5"></i> 
                                <span class="badge bg-primary rounded-pill">0</span>
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-semibold" href="#" data-bs-toggle="dropdown">
                                    <i class="fa-regular fa-user"></i> Mi Taller
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                                            <button type="submit" class="dropdown-item text-danger">Cerrar sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary rounded-pill ms-2 fw-bold" asp-area="Identity" asp-page="/Account/Login">Entrar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @if (TempData["success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="footer text-muted mt-auto border-top pt-4 pb-4 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; 2026 <strong>Repuestos La Central</strong><br />
                    <small>Especialistas en Chevrolet y Fiat — Córdoba, Argentina</small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <span class="me-3 small text-primary fw-semibold"><i class="fa-solid fa-location-dot me-1" style="color: var(--central-yellow);"></i> Alta Córdoba: 351 470-5083</span>
                    <span class="small text-primary fw-semibold"><i class="fa-solid fa-location-dot me-1" style="color: var(--central-yellow);"></i> San Vicente: 351 613-3858</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>