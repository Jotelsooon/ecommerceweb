@{
    ViewData["Title"] = "Nodo Principal de Posventa";
}

<div class="hero-section mb-5 text-white rounded-3 shadow" style="padding: 5.5rem 2rem; background: linear-gradient(135deg, var(--central-blue) 0%, #001a33 100%); border-bottom: 6px solid var(--central-yellow);">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-md-9">
                <h1 class="display-4 fw-black text-uppercase" style="font-weight: 900; letter-spacing: 1px;">Especialistas en Chevrolet y Fiat</h1>
                <p class="lead mb-4 fw-medium mt-3" style="color: #e0e0e0;">El nodo principal para la provisión de soluciones mecánicas en Córdoba. Conocimiento técnico profundo, asesoramiento experto y entrega inmediata para minimizar el tiempo de inactividad de tu vehículo.</p>
                <a href="#" class="btn btn-lg rounded-pill fw-bold px-5 shadow mt-2 btn-central-yellow text-uppercase">Buscar Repuesto</a>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row text-center mb-5">
        <div class="col">
            <h2 class="fw-bold text-primary text-uppercase" style="font-weight: 800;">Rubros Destacados</h2>
            <p class="text-muted fw-semibold">Más de 30 categorías con calidad original y certificada</p>
        </div>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="category-card p-4 border rounded-3 shadow-sm text-center h-100 bg-white" style="border-top: 5px solid var(--central-blue) !important;">
                <i class="fa-solid fa-bolt fs-1 mb-3" style="color: var(--central-yellow);"></i>
                <h4 class="fw-bold text-primary">Sistema de Encendido</h4>
                <p class="text-muted small fw-medium">Bujías, Bobinas, Módulos y Cables. Manejamos el stock crítico para el rendimiento de tu motor (ACDelco, Marelli, Bosch).</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="category-card p-4 border rounded-3 shadow-sm text-center h-100 bg-white" style="border-top: 5px solid var(--central-blue) !important;">
                <i class="fa-solid fa-dharmachakra fs-1 mb-3" style="color: var(--central-yellow);"></i>
                <h4 class="fw-bold text-primary">Rodamientos y Transmisión</h4>
                <p class="text-muted small fw-medium">Soluciones en fricción mecánica. Rodamientos de rueda, caja de cambios y embragues de primera línea (SKF, FAG, NSK).</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="category-card p-4 border rounded-3 shadow-sm text-center h-100 bg-white" style="border-top: 5px solid var(--central-blue) !important;">
                <i class="fa-solid fa-car-burst fs-1 mb-3" style="color: var(--central-yellow);"></i>
                <h4 class="fw-bold text-primary">Suspensión y Frenos</h4>
                <p class="text-muted small fw-medium">Seguridad integral para el entorno urbano. Amortiguadores, pastillas, discos y cilindros (Corven, Monroe, Sachs, Cobreq).</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5 bg-light p-4 rounded shadow-sm border">
    <div class="col-12 text-center">
        <h3 class="fw-bold mb-3 text-primary">Conectividad Omnicanal</h3>
        <p class="text-muted mb-0 fw-medium">Compra online con respaldo físico. Retirá en nuestras sucursales de <strong class="text-primary">Alta Córdoba</strong> (Mariano Fragueiro 3401) o <strong class="text-primary">San Vicente</strong> (San Jerónimo 3027) o pedí envío por Mercado Envíos a todo el país.</p>
    </div>
</div>