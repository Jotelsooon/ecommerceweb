@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-section mb-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h1>Descubre tu propio estilo</h1>
                <p class="mb-4">Explora la nueva colección de temporada. Diseños exclusivos y envíos a todo el país.</p>
                <a href="#" class="btn btn-light btn-lg rounded-pill fw-bold text-primary px-5 shadow-sm">Ver Colección</a>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row text-center mb-4">
        <div class="col">
            <h2 class="fw-bold">Nuestras Categorías</h2>
            <p class="text-muted">Encuentra exactamente lo que buscas</p>
        </div>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="category-card">
                <i class="fa-solid fa-shirt category-icon"></i>
                <h4 class="fw-bold">Indumentaria</h4>
                <p class="text-muted small">Remeras, pantalones, camperas y más.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="category-card">
                <i class="fa-solid fa-shoe-prints category-icon"></i>
                <h4 class="fw-bold">Calzado</h4>
                <p class="text-muted small">Zapatillas urbanas y de vestir.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="category-card">
                <i class="fa-solid fa-glasses category-icon"></i>
                <h4 class="fw-bold">Accesorios</h4>
                <p class="text-muted small">Lentes, gorras, relojes y billeteras.</p>
            </div>
        </div>
    </div>
</div>